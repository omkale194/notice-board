# Copy this file to .env and fill in your own hosted MySQL connection string.
# TiDB Cloud (free) example:
# DATABASE_URL="mysql://<user>:<password>@<host>:4000/<database>?sslaccept=strict"
#
# Neon / Supabase (Postgres) example (also change the `provider` in
# prisma/schema.prisma from "mysql" to "postgresql" if you use one of these):
# DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

DATABASE_URL=""
